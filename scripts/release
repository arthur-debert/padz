#!/usr/bin/env bash
set -euo pipefail

# Thin shim around the canonical release-cut CLI (arthur-debert/release/bin/release-cut).
# release-cut handles arg parsing, semver bump, validation, and dispatches the
# CI release workflow. Run `release-cut --help` for usage.
#
# What CI does (all on GitHub):
#   1. Bumps [workspace.package] version + intra-workspace pin in
#      crates/padz/Cargo.toml + Cargo.lock
#   2. Rolls ## [Unreleased] → ## [VERSION] - DATE in CHANGELOG.md
#   3. Commits "chore: Release vX.Y.Z" + tag, creates GitHub Release (draft)
#   4. Builds binaries (macOS arm64+x86_64, linux x86_64+arm64)
#   5. Builds .deb packages, attaches to release
#   6. Flips release from draft → published
#   7. Publishes padzapp and padz to crates.io
#   8. Pushes Homebrew formula to arthur-debert/homebrew-tools

if ! command -v release-cut >/dev/null 2>&1; then
    echo "scripts/release: release-cut not found on \$PATH" >&2
    echo "  install: cd ~/h/release && git pull (release-cut lives in bin/)" >&2
    exit 1
fi

exec release-cut "$@"
