{#- Per-pad tag changes, rendered straight from the core TaggingResult the handler -#}
{#- returns: `affected_pads` (a list of padzapp::index::DisplayPad) plus `outcome`, -#}
{#- an externally-tagged TaggingOutcome carrying exactly one of the variant keys below. -#}
{%- set ns = namespace(action = "", tags = [], modified = 0) -%}
{%- if outcome.Assigned is defined -%}
{%- set ns.action = "assigned" -%}
{%- set ns.tags = outcome.Assigned.requested_tags -%}
{%- set ns.modified = outcome.Assigned.modified_pads -%}
{%- elif outcome.AllAlreadyPresent is defined -%}
{%- set ns.action = "all_already_present" -%}
{%- set ns.tags = outcome.AllAlreadyPresent.requested_tags -%}
{%- set ns.modified = outcome.AllAlreadyPresent.modified_pads -%}
{%- elif outcome.Removed is defined -%}
{%- set ns.action = "removed" -%}
{%- set ns.tags = outcome.Removed.requested_tags -%}
{%- set ns.modified = outcome.Removed.modified_pads -%}
{%- elif outcome.NonePresent is defined -%}
{%- set ns.action = "none_present" -%}
{%- set ns.tags = outcome.NonePresent.requested_tags -%}
{%- set ns.modified = outcome.NonePresent.modified_pads -%}
{%- endif -%}

{#- Affected pads render flat: a tag change names the pads it touched (all depth 0), -#}
{#- with status and peek off, reusing the listing's core-DisplayPad pad line. -#}
{%- set show_status = false -%}
{%- set peek_mode = false -%}
{%- set request = {"uuid": false} -%}
{%- set count = affected_pads | length -%}

{%- if count > 0 -%}
[info]{{ "Untagged" if ns.action in ["removed", "none_present"] else "Tagged" }} {{ count }} {{ "pad" if count == 1 else "pads" }}...[/info]{{ "" | nl }}
{%- endif -%}

{%- for pad in affected_pads -%}
{%- set depth = 0 -%}
{%- include "_list_pad_line.jinja" -%}
{%- endfor -%}

{%- set tag_count = ns.tags | length -%}
{%- set tag_names = ns.tags | join(", ") -%}
{%- if ns.action == "assigned" -%}
[success]Added {{ "tag" if tag_count == 1 else "tags" }} [{{ tag_names }}] to {{ ns.modified }} {{ "pad" if ns.modified == 1 else "pads" }}[/success]{{ "" | nl }}
{%- elif ns.action == "all_already_present" -%}
[info]All pads already have {{ "tag" if tag_count == 1 else "tags" }} [{{ tag_names }}][/info]{{ "" | nl }}
{%- elif ns.action == "removed" -%}
[success]Removed {{ "tag" if tag_count == 1 else "tags" }} [{{ tag_names }}] from {{ ns.modified }} {{ "pad" if ns.modified == 1 else "pads" }}[/success]{{ "" | nl }}
{%- elif ns.action == "none_present" -%}
[info]No pads had {{ "tag" if tag_count == 1 else "tags" }} [{{ tag_names }}][/info]{{ "" | nl }}
{%- endif -%}
