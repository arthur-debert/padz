{#- Human wording for a semantic tag-registry mutation, rendered straight from the -#}
{#- core TagRegistryOutcome: an externally-tagged enum carrying exactly one of the -#}
{#- variant keys below. -#}
{%- if Created is defined -%}
[success]Created tag '{{ Created.name }}'[/success]{{ "" | nl }}
{%- elif Deleted is defined -%}
[success]Deleted tag '{{ Deleted.name }}'[/success]{{ "" | nl }}
{%- if Deleted.affected_pads > 0 -%}
[info]Removed from {{ Deleted.affected_pads }} {{ "pad" if Deleted.affected_pads == 1 else "pads" }}[/info]{{ "" | nl }}
{%- endif -%}
{%- elif Renamed is defined -%}
[success]Renamed tag '{{ Renamed.old_name }}' to '{{ Renamed.new_name }}'[/success]{{ "" | nl }}
{%- if Renamed.affected_pads > 0 -%}
[info]Updated {{ Renamed.affected_pads }} {{ "pad" if Renamed.affected_pads == 1 else "pads" }}[/info]{{ "" | nl }}
{%- endif -%}
{%- endif -%}
